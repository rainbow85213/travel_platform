# App
APP_NAME="TravelPlatform Chatbot Engine"
DEBUG=false

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1024

# Laravel API (내부 통신)
LARAVEL_API_URL=http://localhost/api
LARAVEL_API_TIMEOUT=10
# Sanctum 서비스 토큰: sail artisan sanctum:issue 또는 직접 DB 발급
LARAVEL_SERVICE_TOKEN=

# Redis (LangGraph 체크포인터 — 세션 영속화)
REDIS_URL=redis://localhost:6379

# TourCast API (직접 호출)
TOURCAST_BASE_URL=https://api.tourcast.io/v1
TOURCAST_API_KEY=
TOURCAST_TIMEOUT=10

# CORS 허용 출처 (JSON 배열 형식)
# 프로덕션: '["https://app.example.com","https://api.example.com"]'
ALLOWED_ORIGINS=["http://localhost","http://localhost:8000","http://127.0.0.1"]
