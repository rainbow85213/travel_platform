# App
APP_NAME="TravelPlatform Chatbot Engine"
DEBUG=false

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1024

# Laravel API (내부 통신)
LARAVEL_API_URL=http://localhost/api
LARAVEL_API_TIMEOUT=10
# Sanctum 서비스 토큰: sail artisan sanctum:issue 또는 직접 DB 발급
LARAVEL_SERVICE_TOKEN=

# TourCast API (직접 호출)
TOURCAST_BASE_URL=https://api.tourcast.io/v1
TOURCAST_API_KEY=
TOURCAST_TIMEOUT=10
