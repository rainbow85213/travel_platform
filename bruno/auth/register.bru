meta {
  name: 회원가입
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "name": "홍길동",
    "email": "test@test.com",
    "password": "password",
    "password_confirmation": "password"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("token", res.body.data.token);
  }
}
